#!/usr/bin/env bash
# pre-commit — run the fast CI-equivalent checks before a commit lands.
#
# Covered:
#   * scalafmtCheckAll   — formatting matches .scalafmt.conf across all modules
#   * docs/mdoc          — every `scala mdoc` fence in site/docs/*.md compiles
#   * docs/laikaSite     — internal cross-references resolve, Laika renders
#
# Bypass with `git commit --no-verify` if you need to skip (e.g. a doc-only WIP).

set -euo pipefail

# Only run when there are staged Scala / sbt / markdown changes — skip
# for untouched commits (tag moves, rebases, merge commits with no content).
if ! git diff --cached --quiet --diff-filter=ACMR \
     -- '*.scala' '*.sbt' '*.md' '.scalafmt.conf' 'site/' 'build.sbt' 2>/dev/null
then
  :  # at least one relevant file changed; fall through to checks
else
  exit 0
fi

echo "[pre-commit] running scalafmtCheckAll + docs/mdoc + docs/laikaSite ..."
sbt -no-colors 'scalafmtCheckAll; docs/mdoc; docs/laikaSite'
